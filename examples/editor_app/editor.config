{
  "app": "GQFusion Editor",

  "window": {
    "width": 1400,
    "height": 900,
    "title": "GQFusion Editor",
    "vsync": true
  },

  "ui": {
    "theme": "dark",
    "layout": "default_layout.json",
    "dpi_scale": 1.0
  },

  "rendering": {
    "gpu_ui": true,
    "framegraph": true,
    "compute_effects": true
  },

  "features": {
    "dockable_ui": true,
    "multi_window": false,
    "live_reload": true
  }
}
