{
  "name": "default",
  "version": 1,

  "colors": {
    "background": "#202020",
    "panel": "#2a2a2a",
    "text": "#e0e0e0",
    "accent": "#4a90e2",
    "border": "#3a3a3a"
  },

  "gradient": {
    "type": "linear",
    "angle": 90,
    "stops": [
      { "position": 0.0, "color": "#4a90e2" },
      { "position": 1.0, "color": "#9013fe" }
    ]
  },

  "ui": {
    "border_radius": 6,
    "padding": 8,
    "margin": 6
  },

  "effects": {
    "blur": true,
    "glow": false,
    "shadow": true,
    "shadow_strength": 0.4
  },

  "animation": {
    "duration": 0.25,
    "easing": "ease_in_out"
  }
}
